generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id             Int         @id @default(autoincrement())
  name           String
  category       String?
  searchCategory String?     @map("search_category")
  address        String?
  phone          String?
  website        String?
  rating         String?
  reviewCount    String?     @map("review_count")
  city           String?
  country        String?
  mapsUrl        String?     @map("maps_url")
  scrapedAt      String?     @map("scraped_at")
  domain         String      // crm | no_website | health | b2b | tourism
  phase          Int         @default(1) // 1=Europe | 2=Dubai/UAE | 3=USA
  state          String?                 // US state (phase 3 only)
  status         String      @default("NEW")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  notes           Note[]
  emailLogs       EmailLog[]
  warmupLeads     WarmupBatchLead[]
  whatsappLeads   WhatsAppBatchLead[]
  lighthouseScans LighthouseScan[]
  leadReport      LeadReport?

  @@map("leads")
}

model Note {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  language  String   @default("en") // en | da | no | nl | sv | et | de | fr | is
  domain    String?  // which lead type (null = all)
  subject   String
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  emailLogs EmailLog[]

  @@map("email_templates")
}

model EmailLog {
  id         Int         @id @default(autoincrement())
  leadId     Int         @map("lead_id")
  templateId Int?        @map("template_id")
  sentAt     DateTime    @default(now()) @map("sent_at")
  subject    String
  body       String
  status     String      @default("SENT")
  notes      String?

  lead     Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@map("email_logs")
}

model WarmupPlan {
  id        Int           @id @default(autoincrement())
  phase     Int           @default(0) // 0=all | 1=Europe | 2=Dubai | 3=USA
  startDate DateTime      @map("start_date")
  totalDays Int           @default(130) @map("total_days")
  createdAt DateTime      @default(now()) @map("created_at")
  batches   WarmupBatch[]

  @@map("warmup_plans")
}

model WarmupBatch {
  id        Int               @id @default(autoincrement())
  planId    Int               @map("plan_id")
  dayNumber Int               @map("day_number")
  date      DateTime
  quota     Int
  plan      WarmupPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  leads     WarmupBatchLead[]

  @@map("warmup_batches")
}

model WarmupBatchLead {
  id      Int       @id @default(autoincrement())
  batchId Int       @map("batch_id")
  leadId  Int       @map("lead_id")
  status  String    @default("PENDING")
  sentAt  DateTime? @map("sent_at")

  batch WarmupBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lead  Lead        @relation(fields: [leadId], references: [id])

  @@unique([batchId, leadId])
  @@map("warmup_batch_leads")
}

model WhatsAppPlan {
  id        Int              @id @default(autoincrement())
  phase     Int              @default(1) // 1=Europe | 2=Dubai | 3=USA
  startDate DateTime         @map("start_date")
  totalDays Int              @default(30) @map("total_days")
  createdAt DateTime         @default(now()) @map("created_at")
  batches   WhatsAppBatch[]

  @@map("whatsapp_plans")
}

model WhatsAppBatch {
  id        Int                 @id @default(autoincrement())
  planId    Int                 @map("plan_id")
  dayNumber Int                 @map("day_number")
  date      DateTime
  quota     Int
  plan      WhatsAppPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  leads     WhatsAppBatchLead[]

  @@map("whatsapp_batches")
}

model WhatsAppBatchLead {
  id      Int       @id @default(autoincrement())
  batchId Int       @map("batch_id")
  leadId  Int       @map("lead_id")
  status  String    @default("PENDING") // PENDING | SENT | NO_ANSWER | REPLIED
  sentAt  DateTime? @map("sent_at")

  batch WhatsAppBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  lead  Lead          @relation(fields: [leadId], references: [id])

  @@unique([batchId, leadId])
  @@map("whatsapp_batch_leads")
}

model LighthouseScan {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  url       String
  scannedAt DateTime @default(now()) @map("scanned_at")

  // Security headers
  https       Boolean @default(false)
  hsts        Boolean @default(false)
  xfo         Boolean @default(false)
  csp         Boolean @default(false)
  xcto        Boolean @default(false)
  xssHeader   Boolean @default(false) @map("xss_header")
  secScore    Int     @default(0) @map("sec_score")

  // SEO signals
  hasTitle     Boolean @default(false) @map("has_title")
  hasMeta      Boolean @default(false) @map("has_meta")
  hasH1        Boolean @default(false) @map("has_h1")
  hasCanonical Boolean @default(false) @map("has_canonical")
  hasOg        Boolean @default(false) @map("has_og")
  hasRobots    Boolean @default(false) @map("has_robots")
  hasSitemap   Boolean @default(false) @map("has_sitemap")
  seoScore     Int     @default(0) @map("seo_score")

  // SEM pixels / tracking
  hasGa        Boolean @default(false) @map("has_ga")
  hasGtm       Boolean @default(false) @map("has_gtm")
  hasFbPixel   Boolean @default(false) @map("has_fb_pixel")
  hasLinkedIn  Boolean @default(false) @map("has_linkedin")
  hasSchemaOrg Boolean @default(false) @map("has_schema_org")
  hasHotjar    Boolean @default(false) @map("has_hotjar")
  semScore     Int     @default(0) @map("sem_score")

  statusCode Int?    @map("status_code")
  error      String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lighthouse_scans")
}

model LeadReport {
  id        Int      @id @default(autoincrement())
  leadId    Int      @unique @map("lead_id")
  scannedAt DateTime @default(now()) @map("scanned_at")

  // Page Speed
  loadTimeMs Int? @map("load_time_ms")

  // SSL
  sslValid      Boolean? @map("ssl_valid")
  sslExpiryDays Int?     @map("ssl_expiry_days")
  sslIssuer     String?  @map("ssl_issuer")

  // Mobile
  hasViewport   Boolean? @map("has_viewport")
  hasTouchIcon  Boolean? @map("has_touch_icon")

  // Broken links
  totalLinks  Int?    @map("total_links")
  brokenLinks Int?    @map("broken_links")
  brokenUrls  String? @map("broken_urls") // JSON array

  // Social presence
  hasFacebook  Boolean? @map("has_facebook")
  hasInstagram Boolean? @map("has_instagram")
  hasLinkedIn  Boolean? @map("has_linkedin")
  hasTiktok    Boolean? @map("has_tiktok")
  hasYoutube   Boolean? @map("has_youtube")
  hasTwitter   Boolean? @map("has_twitter")

  // Email deliverability
  hasSPF      Boolean? @map("has_spf")
  hasDKIM     Boolean? @map("has_dkim")
  hasDMARC    Boolean? @map("has_dmarc")
  spfValue    String?  @map("spf_value")
  dmarcPolicy String?  @map("dmarc_policy")

  error String?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_reports")
}
